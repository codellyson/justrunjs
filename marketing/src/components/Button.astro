---
// Variant API matches justdb's marketing Button so the two sites read the
// same. Renders as <a> when `href` is provided, otherwise <button>.
type Variant = 'primary' | 'secondary';

interface Props {
  variant?: Variant;
  href?: string;
  external?: boolean;
  class?: string;
  id?: string;
  // Anything else (e.g. data-* attributes) is forwarded to the rendered
  // element.
  [key: `data-${string}`]: string | undefined;
}

const { variant = 'primary', href, external = false, class: className = '', id, ...rest } = Astro.props;

const base = 'inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg';
const variants: Record<Variant, string> = {
  primary: 'bg-accent hover:bg-accent-hover text-bg',
  secondary: 'border border-border text-primary hover:bg-bg-secondary',
};

const classes = `${base} ${variants[variant]} ${className}`.trim();
---

{href ? (
  <a
    href={href}
    class={classes}
    id={id}
    {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
    {...rest}
  >
    <slot />
  </a>
) : (
  <button type="button" class={classes} id={id} {...rest}>
    <slot />
  </button>
)}
