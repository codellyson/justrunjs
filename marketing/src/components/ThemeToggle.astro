---
// Floating theme picker — mirrors justdb's pattern. A small button bottom-
// right opens a panel; the panel has a mode toggle (light/dark within the
// current theme) and a list of all themes with two-color swatches.
//
// All state lives on the <html> element (data-theme-id / data-theme-mode)
// and in localStorage. The boot script in Layout.astro applies tokens before
// first paint so this component is just UI.
import { BUILT_IN_THEMES } from '../lib/theme-plugins';
---

<div
  id="theme-picker"
  class="fixed bottom-4 right-4 z-50 flex flex-col items-end gap-2"
>
  <div
    id="theme-panel"
    class="hidden relative z-50 border border-border bg-bg rounded-lg p-4 space-y-3 shadow-lg w-72"
    role="dialog"
    aria-label="Appearance"
  >
    <div class="text-xs font-medium text-muted border-b border-border pb-2">
      Appearance
    </div>

    <button
      id="theme-mode-toggle"
      type="button"
      class="w-full text-left px-3 py-2 text-sm font-medium rounded-md border border-border text-primary hover:bg-bg-secondary transition-colors"
    >
      <span data-mode-label="light">Switch to dark</span>
      <span data-mode-label="dark" class="hidden">Switch to light</span>
    </button>

    <div class="text-xs font-medium text-muted border-b border-border pb-2 pt-1">
      Theme
    </div>

    <div class="space-y-1.5 max-h-72 overflow-y-auto">
      {
        BUILT_IN_THEMES.map((t) => (
          <button
            type="button"
            data-theme-option={t.id}
            data-swatch-light={t.swatch.light}
            data-swatch-dark={t.swatch.dark}
            class="theme-option w-full text-left flex items-center gap-2.5 px-2 py-1.5 rounded-md border text-sm transition-colors border-border text-secondary hover:bg-bg-secondary"
          >
            <span
              class="flex-shrink-0 w-7 h-5 rounded border border-border overflow-hidden flex"
              aria-hidden="true"
            >
              <span class="theme-swatch-bg" style={`background-color: ${t.swatch.dark}; flex: 1;`} />
              <span class="theme-swatch-fg" style={`background-color: ${t.swatch.light}; flex: 1;`} />
            </span>
            <span class="flex-1 min-w-0">
              <span class="block font-medium truncate">{t.label}</span>
              {t.description && (
                <span class="block text-[11px] text-muted truncate">{t.description}</span>
              )}
            </span>
            <span class="theme-check text-accent text-xs flex-shrink-0 hidden" aria-label="Active">✓</span>
          </button>
        ))
      }
    </div>
  </div>

  <button
    id="theme-trigger"
    type="button"
    aria-label="Open theme settings"
    title="Theme settings"
    class="relative z-50 w-10 h-10 rounded-lg border border-border bg-bg text-primary shadow-md flex items-center justify-center hover:bg-bg-secondary transition-colors"
  >
    <span id="theme-trigger-icon">◑</span>
  </button>
</div>

<script is:inline>
  (function () {
    var THEME_DATA_EL = document.documentElement;
    var picker = document.getElementById("theme-picker");
    if (!picker) return;
    var panel = document.getElementById("theme-panel");
    var trigger = document.getElementById("theme-trigger");
    var triggerIcon = document.getElementById("theme-trigger-icon");
    var modeToggle = document.getElementById("theme-mode-toggle");

    var VAR_MAP = {
      bg: "--bg",
      bgSecondary: "--bg-secondary",
      border: "--border",
      textPrimary: "--text-primary",
      textSecondary: "--text-secondary",
      textMuted: "--text-muted",
      accent: "--accent",
      accentHover: "--accent-hover",
      accentText: "--accent-text",
      danger: "--danger",
      success: "--success",
      warning: "--warning",
    };

    // The boot script already wrote tokens before paint; we just need a copy
    // of the theme data to drive the picker. Re-use the global stamped by
    // Layout.astro's boot script.
    var THEMES = window.__RUNJS_THEMES__;

    function currentThemeId() {
      return THEME_DATA_EL.dataset.themeId || "espresso";
    }
    function currentMode() {
      return THEME_DATA_EL.dataset.themeMode || "dark";
    }

    function applyVariant(variant, mode) {
      for (var k in VAR_MAP) {
        if (variant[k]) THEME_DATA_EL.style.setProperty(VAR_MAP[k], variant[k]);
      }
      if (mode === "dark") THEME_DATA_EL.classList.add("dark");
      else THEME_DATA_EL.classList.remove("dark");
    }

    function applyTheme(themeId, mode) {
      if (!THEMES || !THEMES[themeId]) return;
      var theme = THEMES[themeId];
      applyVariant(mode === "dark" ? theme.dark : theme.light, mode);
      THEME_DATA_EL.dataset.themeId = themeId;
      THEME_DATA_EL.dataset.themeMode = mode;
      try {
        localStorage.setItem("runjs.theme.id", themeId);
        localStorage.setItem("runjs.theme.mode", mode);
      } catch (_) {}
      refreshUI();
    }

    function refreshUI() {
      var id = currentThemeId();
      var mode = currentMode();
      // Mode toggle button label
      var labels = modeToggle.querySelectorAll("[data-mode-label]");
      labels.forEach(function (el) {
        el.classList.toggle("hidden", el.dataset.modeLabel !== mode);
      });
      // Theme option active state
      var options = picker.querySelectorAll(".theme-option");
      options.forEach(function (btn) {
        var active = btn.dataset.themeOption === id;
        btn.classList.toggle("border-accent", active);
        btn.classList.toggle("bg-accent/10", active);
        btn.classList.toggle("text-primary", active);
        btn.classList.toggle("border-border", !active);
        btn.classList.toggle("text-secondary", !active);
        var check = btn.querySelector(".theme-check");
        if (check) check.classList.toggle("hidden", !active);
      });
      // Trigger icon flips based on mode for a tiny visual cue
      triggerIcon.textContent = mode === "dark" ? "◐" : "◑";
    }

    // Open/close
    trigger.addEventListener("click", function (e) {
      e.stopPropagation();
      panel.classList.toggle("hidden");
    });
    document.addEventListener("click", function (e) {
      if (panel.classList.contains("hidden")) return;
      if (picker.contains(e.target)) return;
      panel.classList.add("hidden");
    });

    // Mode toggle
    modeToggle.addEventListener("click", function () {
      var next = currentMode() === "dark" ? "light" : "dark";
      applyTheme(currentThemeId(), next);
    });

    // Theme options
    picker.querySelectorAll(".theme-option").forEach(function (btn) {
      btn.addEventListener("click", function () {
        applyTheme(btn.dataset.themeOption, currentMode());
        panel.classList.add("hidden");
      });
    });

    refreshUI();
  })();
</script>
