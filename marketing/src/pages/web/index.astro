---
// In-browser editor — bundled through Astro/Vite (NPM imports for CodeMirror,
// @lezer/highlight, @babel/standalone) so module dedup is guaranteed. The
// editor markup is rendered server-side; the runtime mounts in a `client:load`
// script tag below.
//
// global.css runs Tailwind so the floating ThemeToggle's utility classes
// (fixed/bottom-4/etc) resolve here too — without it the picker renders
// unstyled and ends up invisible in the page corner.
import "../../styles/global.css";
import "../../web/style.css";
import { BUILT_IN_THEMES } from "../../lib/theme-plugins";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>justrunjs — in your browser</title>
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <style>
      /* Inline so it always renders, even if style.css 404s. */
      #boot-error {
        position: fixed; inset: 0; padding: 24px 32px;
        background: #1a0f0e; color: #f8b3ad;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 13px; line-height: 1.5; white-space: pre-wrap;
        z-index: 9999; overflow: auto;
      }
      #boot-error h2 { margin: 0 0 8px; font-size: 14px; color: #ffd1cc; }
    </style>
    <script is:inline>
      (function () {
        function show(label, detail) {
          var existing = document.getElementById("boot-error");
          var pre = existing || document.createElement("div");
          pre.id = "boot-error";
          pre.innerHTML =
            '<h2>' + label + '</h2>' +
            (detail || "").toString().replace(/[<>&]/g, function (c) {
              return { "<": "&lt;", ">": "&gt;", "&": "&amp;" }[c];
            });
          if (!existing && document.body) document.body.appendChild(pre);
        }
        window.addEventListener("error", function (e) {
          var d = e.error && e.error.stack ? e.error.stack : (e.message || String(e));
          if (e.filename) d = e.filename + ":" + e.lineno + "\n\n" + d;
          show("Boot error", d);
        });
        window.addEventListener("unhandledrejection", function (e) {
          var r = e.reason;
          show("Unhandled rejection", (r && r.stack) || (r && r.message) || String(r));
        });
      })();
    </script>
  </head>
  <body>
    <!--
      Custom Tauri title bar. Hidden by default; main.js removes the hidden
      class when window.__TAURI__ is detected. On macOS (titleBarStyle:
      Overlay) the OS still paints traffic lights at the top-left, so we
      reserve 80px of safe-area there and skip drawing min/max/close — the
      OS provides them. On Windows/Linux (decorations:false) we draw the
      controls ourselves. The whole bar is `data-tauri-drag-region` so
      clicking and dragging it moves the window.
    -->
    <div id="titlebar" class="titlebar hidden" data-tauri-drag-region>
      <div class="titlebar-name" data-tauri-drag-region>justrunjs</div>
      <div class="titlebar-controls" id="titlebar-controls">
        <button class="titlebar-btn" id="btn-tb-min" title="Minimize" aria-label="Minimize">
          <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
            <line x1="0" y1="5" x2="10" y2="5" stroke="currentColor" stroke-width="1" />
          </svg>
        </button>
        <button class="titlebar-btn" id="btn-tb-max" title="Maximize" aria-label="Maximize">
          <svg class="icon-max" width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
            <rect x="0.5" y="0.5" width="9" height="9" fill="none" stroke="currentColor" stroke-width="1" />
          </svg>
          <svg class="icon-restore" width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
            <rect x="0.5" y="2.5" width="7" height="7" fill="none" stroke="currentColor" stroke-width="1" />
            <path d="M2.5,2.5 L2.5,0.5 L9.5,0.5 L9.5,7.5 L7.5,7.5" fill="none" stroke="currentColor" stroke-width="1" />
          </svg>
        </button>
        <button class="titlebar-btn titlebar-btn-danger" id="btn-tb-close" title="Close" aria-label="Close">
          <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
            <line x1="0" y1="0" x2="10" y2="10" stroke="currentColor" stroke-width="1" />
            <line x1="0" y1="10" x2="10" y2="0" stroke="currentColor" stroke-width="1" />
          </svg>
        </button>
      </div>
    </div>

    <aside id="sidebar" aria-label="actions">
      <button class="icon-btn" id="btn-run" title="Run (⌘↵)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M7 4.5v15l13-7.5z" />
        </svg>
      </button>
      <button class="icon-btn" id="btn-stop" title="Stop">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <rect x="5" y="5" width="14" height="14" rx="1.5" />
        </svg>
      </button>
      <div class="sidebar-spacer"></div>
      <div class="sidebar-status" id="sidebar-status" title="ready">
        <span class="status-dot" aria-hidden="true"></span>
      </div>
      <button class="icon-btn" id="btn-settings" title="Settings">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="3" />
          <path d="M19.14 12.94a7.957 7.957 0 0 0 0-1.88l2.03-1.58a.5.5 0 0 0 .12-.64l-1.92-3.32a.5.5 0 0 0-.61-.22l-2.39.96a8.07 8.07 0 0 0-1.62-.94l-.36-2.54A.5.5 0 0 0 13.91 2h-3.82a.5.5 0 0 0-.5.42l-.36 2.54c-.59.24-1.13.55-1.62.94l-2.39-.96a.5.5 0 0 0-.61.22L2.7 8.48a.5.5 0 0 0 .12.64l2.03 1.58a7.957 7.957 0 0 0 0 1.88L2.82 14.16a.5.5 0 0 0-.12.64l1.92 3.32a.5.5 0 0 0 .61.22l2.39-.96c.49.39 1.03.7 1.62.94l.36 2.54a.5.5 0 0 0 .5.42h3.82a.5.5 0 0 0 .5-.42l.36-2.54c.59-.24 1.13-.55 1.62-.94l2.39.96a.5.5 0 0 0 .61-.22l1.92-3.32a.5.5 0 0 0-.12-.64l-2.03-1.58z" />
        </svg>
      </button>
      <a class="icon-btn" id="btn-home" href="/" title="Back to overview">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 12l9-9 9 9" />
          <path d="M5 10v10h14V10" />
        </svg>
      </a>
    </aside>
    <main>
      <div id="editor">
        <div id="tabs" role="tablist"></div>
        <div id="editor-host"></div>
      </div>
      <div id="splitter" aria-hidden="true"></div>
      <div id="results">
        <button id="btn-expand" class="hidden" title="Toggle full screen" aria-label="Toggle full screen">
          <svg class="icon-expand" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 3 21 3 21 9" />
            <polyline points="9 21 3 21 3 15" />
            <line x1="21" y1="3" x2="14" y2="10" />
            <line x1="3" y1="21" x2="10" y2="14" />
          </svg>
          <svg class="icon-collapse" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="4 14 10 14 10 20" />
            <polyline points="20 10 14 10 14 4" />
            <line x1="14" y1="10" x2="21" y2="3" />
            <line x1="3" y1="21" x2="10" y2="14" />
          </svg>
        </button>
      </div>
    </main>

    <div id="settings-popover" class="settings-popover hidden" role="dialog" aria-label="Settings">
      <div class="settings-section">
        <div class="settings-title">Appearance</div>

        <button id="settings-mode-toggle" type="button" class="settings-mode-btn">
          <span data-mode-label="light">Switch to dark</span>
          <span data-mode-label="dark" class="hidden">Switch to light</span>
        </button>

        <div class="settings-themes">
          {
            BUILT_IN_THEMES.map((t) => (
              <button
                type="button"
                class="theme-option"
                data-theme-option={t.id}
                title={t.label}
              >
                <span class="theme-swatch" aria-hidden="true">
                  <span style={`background-color: ${t.swatch.dark}; flex: 1;`} />
                  <span style={`background-color: ${t.swatch.light}; flex: 1;`} />
                </span>
                <span class="theme-name">{t.label}</span>
                <span class="theme-check" aria-label="Active">✓</span>
              </button>
            ))
          }
        </div>
      </div>

      <div class="settings-section">
        <div class="settings-title">Editor</div>

        <div class="settings-row settings-row-inline">
          <span>Font size</span>
          <input type="number" id="opt-font-size" min="10" max="24" step="1" />
        </div>

        <div class="settings-row settings-row-inline">
          <span>Tab size</span>
          <div class="settings-segmented">
            <label><input type="radio" name="opt-tab-size" value="2" /><span>2</span></label>
            <label><input type="radio" name="opt-tab-size" value="4" /><span>4</span></label>
          </div>
        </div>

        <label class="settings-row">
          <span>Show line numbers</span>
          <input type="checkbox" id="opt-line-numbers" />
        </label>

        <label class="settings-row">
          <span>Word wrap</span>
          <input type="checkbox" id="opt-word-wrap" />
        </label>

        <label class="settings-row">
          <span>Auto-evaluate on type</span>
          <input type="checkbox" id="opt-auto-eval" />
        </label>
      </div>
    </div>

    <script>
      // Theme tokens applied to <html> before stylesheets resolve. Imported
      // here so Astro/Vite bundles it; runs on the main thread synchronously
      // when the module loads.
      import "../../web/theme-boot.ts";
      // Editor runtime. CodeMirror + worker bridge.
      import "../../web/main.ts";
    </script>
  </body>
</html>
