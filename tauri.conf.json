{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "justrunjs",
  "version": "0.1.0",
  "identifier": "rs.runjs.scratchpad",
  "build": {
    "frontendDist": "./marketing/dist",
    "beforeDevCommand": "pnpm build",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "justrunjs",
        "url": "web/index.html",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
