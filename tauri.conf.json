{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "justrunjs",
  "version": "0.1.0",
  "identifier": "justrunjs.runjs.scratchpad",
  "build": {
    "frontendDist": "./marketing/dist",
    "beforeDevCommand": "pnpm build",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "justrunjs",
        "url": "/web/",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "backgroundColor": "#1d1a17"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/codellyson/justrunjs/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3QjFENjk5NDE3NzgxQzcKUldUSGdYZEJtZGF4VnlmY3hTTHhuRXlRcjl1b1JKYjBWN0NydFAvQThHb2U0dnpXeUhBbnNUZ0YK"
    }
  }
}
